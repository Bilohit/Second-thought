[vault]
# Portable default: ~ expands to the current user's home on any OS
# (see config.py:_resolve_path). Override with an absolute path if you
# want the vault somewhere else.
root = "~/second-thought-storage"

[ollama]
base_url = "http://localhost:11434"
model = "llama3.2"
vision_model = "llava"
keep_alive = "30m"   # keep the model resident 30 min between captures (avoids cold reloads)
# Prompt sent to the vision model for image captures. Override to tune behavior
# (e.g. "extract only the code" vs "describe the UI").
vision_prompt = "Describe this image in detail. If it contains code, a UI screenshot, a diagram, or text, transcribe or describe that content precisely."
# If true, image capture hard-fails (raises) when the vision model is missing/unreachable.
# If false (default), capture degrades gracefully and writes a placeholder note instead.
image_required = false
# Client-side timeout (seconds) on the structured chat-completion call to Ollama.
# Guards against a hang (model swap, GPU contention, model loading) blocking the
# pipeline forever; a timeout raises and is caught by the pipeline's LLM-stage
# except block, routing the capture to the scratchpad.
request_timeout_s = 60

[whisper]
model = "base"
device = "auto"
summarize_threshold_tokens = 6000

[capture]
web_max_chars = 8000
youtube_max_chars = 6000
llm_max_retries = 3
llm_temperature = 0.1
# Max meaningful words kept in a generated filename (deterministic cap).
filename_max_words = 2
# Hard ceiling on the filename stem length (excludes extension).
filename_max_chars = 40
# Soft cap on note body length; 0 = unlimited.
note_max_chars = 0
# Captures whose LLM confidence is below this go to the _scratchpad inbox for
# manual review instead of being filed. 0.0 = file everything, 1.0 = review all.
confidence_threshold = 0.9
# How demanding the classifier's system prompt is: "relaxed" (lean toward
# assigning a category), "balanced" (default), or "strict" (only file on a
# clear, unambiguous fit; otherwise low-confidence -> inbox).
llm_scrutiny = "strict"
# OCR-first fast path: for text-heavy screenshots, run RapidOCR before the
# slow vision model and, if it yields enough text, skip LLaVA and treat the
# image as a plain-text capture.
ocr_fast_path_enabled = true
ocr_text_min_chars = 10   # min OCR characters required to skip LLaVA

# Map-Reduce token budgeting for the async YouTube summarizer. The per-chunk
# limit is derived as:
#   max_chunk_tokens = summary_model_context_tokens
#                      - summary_safety_buffer_tokens
#                      - summary_reserved_output_tokens
summary_model_context_tokens = 8192    # model's max context window (Ollama num_ctx for llama3.2)
summary_safety_buffer_tokens = 256     # headroom for the system/instruction prompt + chat template (>= 200)
summary_reserved_output_tokens = 768   # space left for the model's generated summary
summary_chunk_overlap_tokens = 80      # 50-100 tokens carried between consecutive chunks
summary_max_chunks = 40                # hard cap; bounds total LLM calls / runtime
summary_max_concurrency = 3            # parallel Map calls in flight (bound for local Ollama)
reduce_max_depth = 3                   # recursion cap for the Reduce phase
# Text captures above this token count get chunked Map-Reduce tagging plus a
# faithful whole-document decide-context (chunk 1 + section summaries)
# instead of a silent single-pass truncation by the model's context window.
large_text_token_threshold = 3000
auto_describe_new_folders = true

[log]
path = "~/second-thought-storage/.omni_capture/captures.jsonl"

[notifications]
enabled = true
title_prefix = "Second Thought"

[reminders]
delivery = "app"
check_interval_seconds = 30

[gui]
hotkey = "ctrl+shift+space"
# Phone pairing bind host (D5, P8 safety gate). ABSENT or 127.0.0.1 => the
# FastAPI server binds loopback only (default, not reachable by the phone).
# Legacy field, superseded: the Settings "Pairing" toggle now writes
# `[lan] enabled` / `[lan] host` (the same-WiFi LAN file-sync accelerator).
# Remove this host (or leave it absent) to stay loopback-only.
# `secret` (the X-Omni-Secret) is generated and written here
# automatically on first launch — never commit a real value here.
# host = "100.x.y.z"

secret = ""

[ocr]
# Run a dedicated OCR pass (rapidocr-onnxruntime, CPU-only) alongside the
# vision model for image captures. More accurate than the vision model for
# verbatim text/code transcription. Adds latency; off by default.
enabled = false

[youtube]
# folder_name / description / job_ttl_seconds default in code; uncomment to override.
# Whether to keep the full raw transcript section in the note (always written in v1).
write_raw_transcript = true

[look]
chat_min_similarity_high   = 0.45
chat_min_similarity_medium = 0.35
chat_min_similarity_floor  = 0.32
chat_top_k                 = 8
chat_temperature           = 0.2
chat_general_temperature   = 0.7
# Leave blank to use the built-in default chat system prompt.
chat_system_prompt         = ""

[vector]
enabled = true
# Embedding model used for semantic retrieval/merge. Must be an embedding model
# that is actually pulled in Ollama (check with `ollama list`). The previous
# default `nomic-embed-text` was not installed, so every capture logged a
# "non-fatal index error: HTTP Error 404" — `all-minilm` is installed and works.
embed_model = "all-minilm"
top_k = 3
# Candidates below this cosine similarity are dropped instead of being
# injected as "Semantically Related Notes" context (0.14-0.35 is noise here).
min_similarity = 0.4

[lan]
# same-WiFi LAN sync accelerator (contract §11); Drive is always the fallback.
# `key` (base64 NaCl secretbox key) is auto-generated by the GUI on first
# pairing toggle — never commit a real value here.
enabled = false
# host = ""    # desktop LAN IPv4 (auto-filled by the GUI pairing toggle)
# port = 7071  # LAN listener port (distinct from the loopback GUI port)
key = ""

[sync]
# Drive batched-sync scheduler (phase-5 §1.1). A background thread runs one full bidirectional
# sync pass every `interval_minutes` while `enabled`. Off by default until Google OAuth is set up.
# Interval config is a per-device local preference — deliberately NOT synced.
enabled = true
interval_minutes = 0        # minimum 5 (clamped on read)
sync_on_launch = true
sync_after_capture = false   # a capture burst shouldn't thrash Drive; the interval covers it
mirror_captures = false      # K-2: opt-in — mirror origin:capture files to the hub for phone RAG
