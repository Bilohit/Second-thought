{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Second Thought",
  "version": "0.1.0",
  "identifier": "com.bilohit.second-thought",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "label": "main",
        "title": "Second Thought",
        "width": 480,
        "height": 460,
        "minWidth": 36,
        "minHeight": 36,
        "maxWidth": 480,
        "maxHeight": 700,
        "resizable": false,
        "decorations": false,
        "maximizable": false,
        "maximized": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
